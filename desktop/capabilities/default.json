{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-destroy",
    "updater:default",
    "process:default",
    "dialog:allow-open"
  ]
}
